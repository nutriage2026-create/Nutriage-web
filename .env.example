# Plantilla de variables de entorno para NutriAge
# Copia este archivo como .env y rellena los valores reales.
# El .env real NUNCA se sube a git (esta plantilla sí).

# ─── NOTION ───────────────────────────────────────────
NOTION_TOKEN=

# IDs de bases de datos
NOTION_DB_PACIENTES=
NOTION_DB_LEADS=
NOTION_DB_HISTORIAL_AGENTE=

# ─── CAL.COM ──────────────────────────────────────────
CALCOM_API_KEY=
CALCOM_USERNAME=
CALCOM_EVENT_TYPE_ID=

# ─── MAKE.COM ─────────────────────────────────────────
MAKE_API_TOKEN=

# ─── TALLY.SO ─────────────────────────────────────────
TALLY_API_KEY=

# ─── ANTHROPIC (Claude API) ───────────────────────────
ANTHROPIC_API_KEY=

# ─── EMAIL (Gmail SMTP) ───────────────────────────────
# Necesitas activar "App Password" en tu cuenta Google:
# myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ─── AUTENTICACION ────────────────────────────────────
# Genera un secreto fuerte: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
FERNANDA_PASSWORD=

# ─── APP ──────────────────────────────────────────────
APP_ENV=development
TZ=America/Santiago
